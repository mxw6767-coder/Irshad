{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Irshad",
  "version": "0.1.0",
  "identifier": "com.irshad.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../.next",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "Irshad",
        "width": 1440,
        "height": 960,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "shortDescription": "Private encrypted messenger for two trusted users.",
    "longDescription": "Irshad is a private end-to-end encrypted messenger for two trusted users.",
    "publisher": "Irshad",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
